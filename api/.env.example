# Credenciales de Azure OpenAI (rellenar con tus valores)
# El endpoint debe terminar en barra "/"
AZURE_ENDPOINT=https://<tu-recurso>.openai.azure.com/
AZURE_API_KEY=
API_VERSION=2024-02-15-preview
DEPLOYMENT_NAME=

# Verificación SSL del cliente Azure. Por defecto "false" (útil tras proxies
# corporativos con certificados propios). Pon "true" en entornos con TLS válido.
AZURE_VERIFY_SSL=false
